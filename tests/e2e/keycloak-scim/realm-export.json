{
  "realm": "ccag-test",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "user", "description": "Regular user" },
      { "name": "admin", "description": "Admin user" }
    ]
  },
  "clients": [
    {
      "clientId": "ccag-gateway",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "email", "profile"],
      "optionalClientScopes": [],
      "protocolMappers": [
        {
          "name": "subject",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "ccag-gateway",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "email": "alice@ccag-test.example.com",
      "firstName": "Alice",
      "lastName": "Test",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice-pass",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "bob",
      "email": "bob@ccag-test.example.com",
      "firstName": "Bob",
      "lastName": "Test",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob-pass",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    }
  ]
}
